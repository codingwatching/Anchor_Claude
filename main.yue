global *

require 'game.init'

frame = 0
test_num = 0

log = (msg) ->
  print "  #{msg}"

test = (name, fn) ->
  test_num += 1
  print "\n=== Test #{test_num}: #{name} ==="
  fn!

names = (list) ->
  table.concat [obj.name for obj in *list], ', '

-- Test 1: Complex tree structure
test_complex_tree = ->
  test "Complex tree (4 levels deep)", ->
    an\add object 'a'
    an.a\add object 'b'
    an.a.b\add object 'c'
    an.a.b.c\add object 'd'
    an.a\add object 'e'
    an\add object 'f'
    an.f\add object 'g'
    an.f\add object 'h'
    an.f.h\add object 'i'
    an.f.h\add object 'j'
    an\add object 'k'
    log "All: #{names an\all!}"
    log "Expected: a, b, c, d, e, f, g, h, i, j, k"
    log "Count: #{#an\all!}"

-- Test 2: Bidirectional links
test_bidirectional = ->
  test "Bidirectional named links", ->
    log "an.a exists: #{an.a != nil}"
    log "an.a.an == an: #{an.a.an == an}"
    log "an.f.h.f == an.f: #{an.f.h.f == an.f}"
    log "an.a.b.c.d.c == an.a.b.c: #{an.a.b.c.d.c == an.a.b.c}"

-- Test 3: Tags and is()
test_tags = ->
  test "Tags and is() method", ->
    an.a\tag 'enemy', 'flying'
    an.a.b\tag 'enemy'
    an.f\tag 'friendly'
    an.f.h\tag 'enemy', 'boss'
    log "Enemies: #{names an\all 'enemy'}"
    log "Flying: #{names an\all 'flying'}"
    log "Bosses: #{names an\all 'boss'}"
    log "a\\is 'enemy': #{an.a\is 'enemy'}"
    log "a\\is 'a': #{an.a\is 'a'}"

-- Test 4: Kill middle branch
test_kill_middle = ->
  test "Kill middle of tree (b branch)", ->
    log "Before: #{names an\all!}"
    an.a.b\kill!
    log "After kill (same frame): b.dead=#{an.a.b.dead}, c.dead=#{an.a.b.c.dead}"
    log "a.dead: #{an.a.dead}, e.dead: #{an.a.e.dead}"

-- Test 5: After cleanup
test_after_middle_cleanup = ->
  test "After cleanup (middle branch removed)", ->
    log "All: #{names an\all!}"
    log "an.a.b: #{an.a.b}"

-- Test 6: Named child replacement
test_replacement = ->
  test "Named child replacement", ->
    old_g = an.f.g
    an.f\add object 'g'
    log "Old g dead: #{old_g.dead}"
    log "New g is different: #{an.f.g != old_g}"

-- Test 7: Kill by tag
test_kill_by_tag = ->
  test "Kill by tag 'enemy'", ->
    log "Before: #{names an\all!}"
    an\kill 'enemy'
    log "a.dead: #{an.a.dead}, f.dead: #{an.f.dead}, k.dead: #{an.k.dead}"

-- Test 8: After tag kill
test_after_tag_kill = ->
  test "After tag kill cleanup", ->
    log "All: #{names an\all!}"

-- Test 9: Action that returns true (one-shot)
test_oneshot_action = ->
  test "One-shot action (returns true)", ->
    an\add object 'm'
    counter = 0
    an.m\action ->
      counter += 1
      log "One-shot ran, counter=#{counter}"
      true
    log "Action added, will run next frame"

-- Test 10: After one-shot
test_after_oneshot = ->
  test "After one-shot (should not run again)", ->
    log "If counter is still 1, one-shot was removed"

-- Test 11: Named action
test_named_action = ->
  test "Named action", ->
    an.m\action 'counter', ->
      an.m.count = (an.m.count or 0) + 1
      log "Named action ran, count=#{an.m.count}"
    log "an.m.counter exists: #{an.m.counter != nil}"

-- Test 12: Named action runs
test_named_action_runs = ->
  test "Named action runs each frame", ->
    log "count=#{an.m.count}"

-- Test 13: Replace named action
test_replace_action = ->
  test "Replace named action", ->
    old_action = an.m.counter
    an.m\action 'counter', ->
      an.m.count2 = (an.m.count2 or 0) + 1
      log "Replaced action ran, count2=#{an.m.count2}"
    log "Action replaced: #{an.m.counter != old_action}"

-- Test 14: Replaced action runs
test_replaced_runs = ->
  test "Replaced action runs", ->
    log "count2=#{an.m.count2}, count=#{an.m.count} (should stop incrementing)"

-- Test 15: Early and late actions
test_early_late = ->
  test "Early and late actions", ->
    an\add object 'p'
    an.p.order = {}
    an.p\early_action ->
      an.p.order[] = 'early'
    an.p\action ->
      an.p.order[] = 'main'
    an.p\late_action ->
      an.p.order[] = 'late'
    log "Actions added, will run next frame"

-- Test 16: Check order
test_order = ->
  test "Action execution order", ->
    log "Order: #{table.concat an.p.order, ', '}"
    log "Expected: early, main, late"

-- Test 17: Named early/late actions
test_named_early_late = ->
  test "Named early/late actions", ->
    an.p\early_action 'my_early', ->
      an.p.early_count = (an.p.early_count or 0) + 1
    an.p\late_action 'my_late', ->
      an.p.late_count = (an.p.late_count or 0) + 1
    log "an.p.my_early exists: #{an.p.my_early != nil}"
    log "an.p.my_late exists: #{an.p.my_late != nil}"

-- Test 18: Named early/late run
test_named_early_late_run = ->
  test "Named early/late run each frame", ->
    log "early_count=#{an.p.early_count}, late_count=#{an.p.late_count}"

-- Test 19: One-shot early/late
test_oneshot_early_late = ->
  test "One-shot early/late actions", ->
    an.p\early_action ->
      log "One-shot early ran"
      true
    an.p\late_action ->
      log "One-shot late ran"
      true
    log "One-shot early/late added"

-- Test 20: After one-shot early/late
test_after_oneshot_early_late = ->
  test "After one-shot early/late", ->
    log "One-shots should have run once and been removed"
    log "early_count=#{an.p.early_count}, late_count=#{an.p.late_count}"

-- Test 22: Link with callback (survives)
test_link_callback = ->
  test "Link with callback (object survives)", ->
    an\add object 'shooter'
    an\add object 'bullet'
    an.bullet.homing = true
    an.bullet\link an.shooter, =>
      @homing = false
      log "Callback ran, homing=#{@homing}"
    log "bullet linked to shooter"
    an.shooter\kill!
    log "shooter killed, bullet.dead=#{an.bullet.dead}, bullet.homing=#{an.bullet.homing}"

-- Test 23: After link callback
test_after_link_callback = ->
  test "After link callback (bullet still alive)", ->
    log "bullet exists: #{an.bullet != nil}"
    log "bullet.dead: #{an.bullet.dead}"
    log "shooter removed: #{an.shooter == nil}"

-- Test 24: Link with callback that kills self
test_link_callback_kills = ->
  test "Link with callback that kills self", ->
    an\add object 'owner'
    an\add object 'pet'
    an.pet.said_goodbye = false
    an.pet\link an.owner, =>
      @said_goodbye = true
      log "Pet says goodbye"
      @\kill!
    log "pet linked to owner"
    an.owner\kill!
    log "owner killed, pet.dead=#{an.pet.dead}, pet.said_goodbye=#{an.pet.said_goodbye}"

-- Test 25: After callback kill
test_after_callback_kill = ->
  test "After callback kill (both removed)", ->
    log "owner exists: #{an.owner}"
    log "pet exists: #{an.pet}"

-- Test 26: Link without callback (default kill)
test_link_default = ->
  test "Link without callback (default kill)", ->
    an\add object 'parent_obj'
    an\add object 'child_obj'
    an.child_obj\link an.parent_obj
    log "child_obj linked to parent_obj (no callback)"
    an.parent_obj\kill!
    log "parent_obj killed, child_obj.dead=#{an.child_obj.dead}"

-- Test 27: After default kill
test_after_default_kill = ->
  test "After default kill (both removed)", ->
    log "parent_obj exists: #{an.parent_obj}"
    log "child_obj exists: #{an.child_obj}"

-- Test 28: Circular links
test_circular_links = ->
  test "Circular links", ->
    an\add object 'node_a'
    an\add object 'node_b'
    an.node_a\link an.node_b
    an.node_b\link an.node_a
    log "node_a and node_b linked to each other"
    an.node_a\kill!
    log "node_a killed, node_a.dead=#{an.node_a.dead}, node_b.dead=#{an.node_b.dead}"

-- Test 29: After circular kill
test_after_circular = ->
  test "After circular kill (both removed)", ->
    log "node_a exists: #{an.node_a}"
    log "node_b exists: #{an.node_b}"

-- Test 30: Link cleanup when linker dies
test_link_cleanup = ->
  test "Link cleanup when linker dies", ->
    an\add object 'target'
    an\add object 'linker'
    an.linker\link an.target, =>
      log "This should not run"
    log "target.linked_from count: #{#an.target.linked_from}"
    an.linker\kill!
    log "linker killed (not target)"

-- Test 31: After linker cleanup
test_after_linker_cleanup = ->
  test "After linker cleanup (linked_from cleaned)", ->
    log "target exists: #{an.target != nil}"
    log "target.linked_from count: #{an.target.linked_from and #an.target.linked_from or 0}"
    an.target\kill!

-- Test 32: T alias (object)
test_T_alias = ->
  test "T alias (object)", ->
    o = T 'alias_test'
    an\add o
    log "T created object: #{an.alias_test != nil}"
    log "name: #{an.alias_test.name}"

-- Test 33: Y alias (set)
test_Y_alias = ->
  test "Y alias (set)", ->
    an.alias_test\Y {x: 100, y: 200, hp: 50}
    log "x=#{an.alias_test.x}, y=#{an.alias_test.y}, hp=#{an.alias_test.hp}"

-- Test 34: U alias (build)
test_U_alias = ->
  test "U alias (build)", ->
    an.alias_test\U =>
      @speed = @x + @y
      @ready = true
    log "speed=#{an.alias_test.speed}, ready=#{an.alias_test.ready}"

-- Test 35: A alias (add)
test_A_alias = ->
  test "A alias (add)", ->
    an.alias_test\A object 'child_a'
    log "child added: #{an.alias_test.child_a != nil}"

-- Test 36: E, X, L aliases (actions)
test_action_aliases = ->
  test "E, X, L aliases (actions)", ->
    an\add object 'action_alias_test'
    an.action_alias_test.order = {}
    an.action_alias_test\E ->
      an.action_alias_test.order[] = 'E'
      true  -- one-shot
    an.action_alias_test\X ->
      an.action_alias_test.order[] = 'X'
      true  -- one-shot
    an.action_alias_test\L ->
      an.action_alias_test.order[] = 'L'
      true  -- one-shot
    log "Actions added via aliases"

-- Test 37: After action aliases (wait one frame for all phases to complete)
test_after_action_aliases_wait = ->
  test "After action aliases (waiting)", ->
    log "Letting E, X, L run..."

-- Test 38: After action aliases (check order)
test_after_action_aliases = ->
  test "After action aliases (order check)", ->
    log "Order: #{table.concat an.action_alias_test.order, ', '}"
    log "Expected: E, X, L"
    an.action_alias_test\kill!

-- Test 39: F alias (flow_to)
test_F_alias = ->
  test "F alias (flow_to)", ->
    o = T 'flow_test'
    o\Y {x: 50}
    o\F an
    log "flow_to worked: #{an.flow_test != nil}"
    log "x=#{an.flow_test.x}"

-- Test 40: K alias (link)
test_K_alias = ->
  test "K alias (link)", ->
    an\add object 'link_target'
    an\add object 'link_source'
    an.link_source.survived = false
    an.link_source\K an.link_target, =>
      @survived = true
    an.link_target\kill!
    log "link callback ran: #{an.link_source.survived}"

-- Test 41: After K alias
test_after_K_alias = ->
  test "After K alias (cleanup)", ->
    log "link_target removed: #{an.link_target == nil}"
    log "link_source survived: #{an.link_source != nil}"
    an.link_source\kill!
    an.alias_test\kill!
    an.flow_test\kill!

-- Test 42: Final
test_final = ->
  test "Final state", ->
    log "All: #{names an\all!}"
    print "\n=== All tests complete ==="

an\action ->
  frame += 1
  if frame == 1
    test_complex_tree!
  elseif frame == 2
    test_bidirectional!
    test_tags!
  elseif frame == 3
    test_kill_middle!
  elseif frame == 4
    test_after_middle_cleanup!
    test_replacement!
  elseif frame == 5
    test_kill_by_tag!
  elseif frame == 6
    test_after_tag_kill!
    test_oneshot_action!
  elseif frame == 7
    test_after_oneshot!
    test_named_action!
  elseif frame == 8
    test_named_action_runs!
  elseif frame == 9
    test_replace_action!
  elseif frame == 10
    test_replaced_runs!
  elseif frame == 11
    test_early_late!
  elseif frame == 12
    test_named_early_late!
  elseif frame == 13
    test_order!
    test_named_early_late_run!
  elseif frame == 14
    test_oneshot_early_late!
  elseif frame == 15
    test_after_oneshot_early_late!
  elseif frame == 16
    test_link_callback!
  elseif frame == 17
    test_after_link_callback!
    test_link_callback_kills!
  elseif frame == 18
    test_after_callback_kill!
    test_link_default!
  elseif frame == 19
    test_after_default_kill!
    test_circular_links!
  elseif frame == 20
    test_after_circular!
    test_link_cleanup!
  elseif frame == 21
    test_after_linker_cleanup!
  elseif frame == 22
    test_T_alias!
    test_Y_alias!
    test_U_alias!
  elseif frame == 23
    test_A_alias!
    test_action_aliases!
  elseif frame == 24
    test_after_action_aliases_wait!
  elseif frame == 25
    test_after_action_aliases!
  elseif frame == 26
    test_F_alias!
  elseif frame == 27
    test_K_alias!
  elseif frame == 28
    test_after_K_alias!
  elseif frame == 29
    test_final!
