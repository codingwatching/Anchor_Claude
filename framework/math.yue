global *

--[[
  Math utility functions and easing curves.

  Utility functions:
    lerp, lerp_dt             - Linear interpolation
    lerp_angle, lerp_angle_dt - Angle interpolation with wrapping
    clamp                     - Clamp value to range
    remap                     - Remap value from one range to another
    loop                      - Loop value within range (for angles)

  Easing functions:
    linear, sine_*, quad_*, cubic_*, quart_*, quint_*,
    expo_*, circ_*, bounce_*, back_*, elastic_*
]]

-- Constants for easing functions
PI = math.pi
PI2 = math.pi / 2
LN2 = math.log 2
LN210 = 10 * math.log 2

-- Overshoot for back easing
overshoot = 1.70158

-- Amplitude and period for elastic easing
amplitude = 1
period = 0.0003

--[[
  Linearly interpolates between source and destination.

  Usage:
    math.lerp 0.5, 0, 100   -> 50
    math.lerp 0, 0, 100     -> 0
    math.lerp 1, 0, 100     -> 100

  Parameters:
    t           - Interpolation factor (0 = source, 1 = destination)
    source      - Start value
    destination - End value

  Returns: interpolated value
]]
math.lerp = (t, source, destination) ->
  source * (1 - t) + destination * t

--[[
  Framerate-independent linear interpolation.

  Usage:
    x = math.lerp_dt 0.9, 1, dt, x, target   -> covers 90% of distance in 1 second
    x = math.lerp_dt 0.5, 0.5, dt, x, target -> covers 50% of distance in 0.5 seconds

  Parameters:
    p           - Percentage of distance to cover (0.9 = 90%)
    t           - Time in seconds to cover that percentage
    dt          - Delta time
    source      - Current value
    destination - Target value

  Returns: new value moved towards destination

  Behavior:
    - Exponential approach: value gets closer but never quite reaches target
    - Useful for smooth camera follow, UI animations, etc.
]]
math.lerp_dt = (p, t, dt, source, destination) ->
  math.lerp 1 - (1 - p)^(dt / t), source, destination

--[[
  Loops value t to stay within [0, length] range.

  Usage:
    math.loop 3 * math.pi, 2 * math.pi  -> math.pi
    math.loop 5, 3                       -> 2
    math.loop -1, 4                      -> 3

  Parameters:
    t      - Value to loop
    length - Range length (result will be in [0, length])

  Returns: looped value

  Behavior:
    - Useful for keeping angles in [0, 2*pi] range
    - Handles negative values correctly
]]
math.loop = (t, length) ->
  math.clamp t - math.floor(t / length) * length, 0, length

--[[
  Linearly interpolates between angles with correct wrapping.

  Usage:
    math.lerp_angle 0.5, 0, math.pi          -> math.pi/2
    math.lerp_angle 0.5, -math.pi, math.pi   -> 0 (takes shortest path)

  Parameters:
    t           - Interpolation factor (0 = source, 1 = destination)
    source      - Start angle in radians
    destination - End angle in radians

  Returns: interpolated angle

  Behavior:
    - Takes the shortest path around the circle
    - Keeps result in valid angle range
]]
math.lerp_angle = (t, source, destination) ->
  dt = math.loop destination - source, 2 * math.pi
  if dt > math.pi then dt = dt - 2 * math.pi
  source + dt * math.clamp t, 0, 1

--[[
  Framerate-independent angle interpolation with correct wrapping.

  Usage:
    angle = math.lerp_angle_dt 0.9, 1, dt, angle, target_angle

  Parameters:
    p           - Percentage of distance to cover (0.9 = 90%)
    t           - Time in seconds to cover that percentage
    dt          - Delta time
    source      - Current angle in radians
    destination - Target angle in radians

  Returns: new angle moved towards destination

  Behavior:
    - Takes the shortest path around the circle
    - Exponential approach like lerp_dt
]]
math.lerp_angle_dt = (p, t, dt, source, destination) ->
  math.lerp_angle 1 - (1 - p)^(dt / t), source, destination

--[[
  Clamps value to stay within [min, max] range.

  Usage:
    math.clamp 5, 0, 10   -> 5
    math.clamp -5, 0, 10  -> 0
    math.clamp 15, 0, 10  -> 10

  Parameters:
    value - Value to clamp
    min   - Minimum bound
    max   - Maximum bound

  Returns: clamped value
]]
math.clamp = (value, min, max) ->
  if value < min then min
  elseif value > max then max
  else value

--[[
  Remaps a value from one range to another.

  Usage:
    math.remap 10, 0, 20, 0, 1       -> 0.5 (10 is 50% of [0, 20], maps to 50% of [0, 1])
    math.remap 3, 0, 3, 0, 100      -> 100
    math.remap 2.5, -5, 5, -100, 100 -> 50
    math.remap -10, 0, 10, 0, 1000  -> -1000 (extrapolates outside range)

  Parameters:
    value   - Value to remap
    old_min - Original range minimum
    old_max - Original range maximum
    new_min - Target range minimum
    new_max - Target range maximum

  Returns: value mapped from old range to new range

  Behavior:
    - Does not clamp: values outside old range will extrapolate
    - To clamp, combine with math.clamp on input or output
]]
math.remap = (value, old_min, old_max, new_min, new_max) ->
  ((value - old_min)/(old_max - old_min))*(new_max - new_min) + new_min

-- Linear (no easing)
math.linear = (t) -> t

-- Sine easing
math.sine_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else 1 - math.cos t * PI2

math.sine_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else math.sin t * PI2

math.sine_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else -0.5 * (math.cos(t * PI) - 1)

math.sine_out_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  elseif t < 0.5 then 0.5 * math.sin(t * 2 * PI2)
  else -0.5 * math.cos((t * 2 - 1) * PI2) + 1

-- Quad easing
math.quad_in = (t) -> t * t

math.quad_out = (t) -> -t * (t - 2)

math.quad_in_out = (t) ->
  if t < 0.5
    2 * t * t
  else
    t = t - 1
    -2 * t * t + 1

math.quad_out_in = (t) ->
  if t < 0.5
    t = t * 2
    -0.5 * t * (t - 2)
  else
    t = t * 2 - 1
    0.5 * t * t + 0.5

-- Cubic easing
math.cubic_in = (t) -> t * t * t

math.cubic_out = (t) ->
  t = t - 1
  t * t * t + 1

math.cubic_in_out = (t) ->
  t = t * 2
  if t < 1
    0.5 * t * t * t
  else
    t = t - 2
    0.5 * (t * t * t + 2)

math.cubic_out_in = (t) ->
  t = t * 2 - 1
  0.5 * (t * t * t + 1)

-- Quart easing
math.quart_in = (t) -> t * t * t * t

math.quart_out = (t) ->
  t = t - 1
  t = t * t
  1 - t * t

math.quart_in_out = (t) ->
  t = t * 2
  if t < 1
    0.5 * t * t * t * t
  else
    t = t - 2
    t = t * t
    -0.5 * (t * t - 2)

math.quart_out_in = (t) ->
  if t < 0.5
    t = t * 2 - 1
    t = t * t
    -0.5 * t * t + 0.5
  else
    t = t * 2 - 1
    t = t * t
    0.5 * t * t + 0.5

-- Quint easing
math.quint_in = (t) -> t * t * t * t * t

math.quint_out = (t) ->
  t = t - 1
  t * t * t * t * t + 1

math.quint_in_out = (t) ->
  t = t * 2
  if t < 1
    0.5 * t * t * t * t * t
  else
    t = t - 2
    0.5 * t * t * t * t * t + 1

math.quint_out_in = (t) ->
  t = t * 2 - 1
  0.5 * (t * t * t * t * t + 1)

-- Expo easing
math.expo_in = (t) ->
  if t == 0 then 0
  else math.exp LN210 * (t - 1)

math.expo_out = (t) ->
  if t == 1 then 1
  else 1 - math.exp -LN210 * t

math.expo_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t * 2
    if t < 1 then 0.5 * math.exp LN210 * (t - 1)
    else 0.5 * (2 - math.exp -LN210 * (t - 1))

math.expo_out_in = (t) ->
  if t < 0.5 then 0.5 * (1 - math.exp -20 * LN2 * t)
  elseif t == 0.5 then 0.5
  else 0.5 * (math.exp(20 * LN2 * (t - 1)) + 1)

-- Circ easing
math.circ_in = (t) ->
  if t < -1 or t > 1 then 0
  else 1 - math.sqrt 1 - t * t

math.circ_out = (t) ->
  if t < 0 or t > 2 then 0
  else math.sqrt t * (2 - t)

math.circ_in_out = (t) ->
  if t < -0.5 or t > 1.5 then 0.5
  else
    t = t * 2
    if t < 1 then -0.5 * (math.sqrt(1 - t * t) - 1)
    else
      t = t - 2
      0.5 * (math.sqrt(1 - t * t) + 1)

math.circ_out_in = (t) ->
  if t < 0 then 0
  elseif t > 1 then 1
  elseif t < 0.5
    t = t * 2 - 1
    0.5 * math.sqrt 1 - t * t
  else
    t = t * 2 - 1
    -0.5 * ((math.sqrt(1 - t * t) - 1) - 1)

-- Bounce easing
math.bounce_in = (t) ->
  t = 1 - t
  if t < 1 / 2.75 then 1 - 7.5625 * t * t
  elseif t < 2 / 2.75
    t = t - 1.5 / 2.75
    1 - (7.5625 * t * t + 0.75)
  elseif t < 2.5 / 2.75
    t = t - 2.25 / 2.75
    1 - (7.5625 * t * t + 0.9375)
  else
    t = t - 2.625 / 2.75
    1 - (7.5625 * t * t + 0.984375)

math.bounce_out = (t) ->
  if t < 1 / 2.75 then 7.5625 * t * t
  elseif t < 2 / 2.75
    t = t - 1.5 / 2.75
    7.5625 * t * t + 0.75
  elseif t < 2.5 / 2.75
    t = t - 2.25 / 2.75
    7.5625 * t * t + 0.9375
  else
    t = t - 2.625 / 2.75
    7.5625 * t * t + 0.984375

math.bounce_in_out = (t) ->
  if t < 0.5
    t = 1 - t * 2
    if t < 1 / 2.75 then (1 - 7.5625 * t * t) * 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      (1 - (7.5625 * t * t + 0.75)) * 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      (1 - (7.5625 * t * t + 0.9375)) * 0.5
    else
      t = t - 2.625 / 2.75
      (1 - (7.5625 * t * t + 0.984375)) * 0.5
  else
    t = t * 2 - 1
    if t < 1 / 2.75 then 7.5625 * t * t * 0.5 + 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      (7.5625 * t * t + 0.75) * 0.5 + 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      (7.5625 * t * t + 0.9375) * 0.5 + 0.5
    else
      t = t - 2.625 / 2.75
      (7.5625 * t * t + 0.984375) * 0.5 + 0.5

math.bounce_out_in = (t) ->
  if t < 0.5
    t = t * 2
    if t < 1 / 2.75 then 7.5625 * t * t * 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      (7.5625 * t * t + 0.75) * 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      (7.5625 * t * t + 0.9375) * 0.5
    else
      t = t - 2.625 / 2.75
      (7.5625 * t * t + 0.984375) * 0.5
  else
    t = 1 - (t * 2 - 1)
    if t < 1 / 2.75 then 0.5 - 7.5625 * t * t * 0.5 + 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      0.5 - (7.5625 * t * t + 0.75) * 0.5 + 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      0.5 - (7.5625 * t * t + 0.9375) * 0.5 + 0.5
    else
      t = t - 2.625 / 2.75
      0.5 - (7.5625 * t * t + 0.984375) * 0.5 + 0.5

-- Back easing
math.back_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else t * t * ((overshoot + 1) * t - overshoot)

math.back_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t - 1
    t * t * ((overshoot + 1) * t + overshoot) + 1

math.back_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t * 2
    if t < 1 then 0.5 * (t * t * ((overshoot * 1.525 + 1) * t - overshoot * 1.525))
    else
      t = t - 2
      0.5 * (t * t * ((overshoot * 1.525 + 1) * t + overshoot * 1.525) + 2)

math.back_out_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  elseif t < 0.5
    t = t * 2 - 1
    0.5 * (t * t * ((overshoot + 1) * t + overshoot) + 1)
  else
    t = t * 2 - 1
    0.5 * t * t * ((overshoot + 1) * t - overshoot) + 0.5

-- Elastic easing
math.elastic_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t - 1
    -(amplitude * math.exp(LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period))

math.elastic_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else math.exp(-LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period) + 1

math.elastic_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t * 2
    if t < 1
      t = t - 1
      -0.5 * (amplitude * math.exp(LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period))
    else
      t = t - 1
      amplitude * math.exp(-LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period) * 0.5 + 1

math.elastic_out_in = (t) ->
  if t < 0.5
    t = t * 2
    if t == 0 then 0
    else (amplitude / 2) * math.exp(-LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period) + 0.5
  else
    if t == 0.5 then 0.5
    elseif t == 1 then 1
    else
      t = t * 2 - 1
      t = t - 1
      -((amplitude / 2) * math.exp(LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period)) + 0.5
