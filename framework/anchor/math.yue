global *

-- Constants for easing functions
PI = math.pi
PI2 = math.pi / 2
LN2 = math.log 2
LN210 = 10 * math.log 2

-- Overshoot for back easing
overshoot = 1.70158

-- Amplitude and period for elastic easing
amplitude = 1
period = 0.0003

-- Linearly interpolates between source and destination with lerp value t
math.lerp = (t, source, destination) ->
  source * (1 - t) + destination * t

-- Linear (no easing)
math.linear = (t) -> t

-- Sine easing
math.sine_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else 1 - math.cos t * PI2

math.sine_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else math.sin t * PI2

math.sine_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else -0.5 * (math.cos(t * PI) - 1)

math.sine_out_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  elseif t < 0.5 then 0.5 * math.sin(t * 2 * PI2)
  else -0.5 * math.cos((t * 2 - 1) * PI2) + 1

-- Quad easing
math.quad_in = (t) -> t * t

math.quad_out = (t) -> -t * (t - 2)

math.quad_in_out = (t) ->
  if t < 0.5
    2 * t * t
  else
    t = t - 1
    -2 * t * t + 1

math.quad_out_in = (t) ->
  if t < 0.5
    t = t * 2
    -0.5 * t * (t - 2)
  else
    t = t * 2 - 1
    0.5 * t * t + 0.5

-- Cubic easing
math.cubic_in = (t) -> t * t * t

math.cubic_out = (t) ->
  t = t - 1
  t * t * t + 1

math.cubic_in_out = (t) ->
  t = t * 2
  if t < 1
    0.5 * t * t * t
  else
    t = t - 2
    0.5 * (t * t * t + 2)

math.cubic_out_in = (t) ->
  t = t * 2 - 1
  0.5 * (t * t * t + 1)

-- Quart easing
math.quart_in = (t) -> t * t * t * t

math.quart_out = (t) ->
  t = t - 1
  t = t * t
  1 - t * t

math.quart_in_out = (t) ->
  t = t * 2
  if t < 1
    0.5 * t * t * t * t
  else
    t = t - 2
    t = t * t
    -0.5 * (t * t - 2)

math.quart_out_in = (t) ->
  if t < 0.5
    t = t * 2 - 1
    t = t * t
    -0.5 * t * t + 0.5
  else
    t = t * 2 - 1
    t = t * t
    0.5 * t * t + 0.5

-- Quint easing
math.quint_in = (t) -> t * t * t * t * t

math.quint_out = (t) ->
  t = t - 1
  t * t * t * t * t + 1

math.quint_in_out = (t) ->
  t = t * 2
  if t < 1
    0.5 * t * t * t * t * t
  else
    t = t - 2
    0.5 * t * t * t * t * t + 1

math.quint_out_in = (t) ->
  t = t * 2 - 1
  0.5 * (t * t * t * t * t + 1)

-- Expo easing
math.expo_in = (t) ->
  if t == 0 then 0
  else math.exp LN210 * (t - 1)

math.expo_out = (t) ->
  if t == 1 then 1
  else 1 - math.exp -LN210 * t

math.expo_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t * 2
    if t < 1 then 0.5 * math.exp LN210 * (t - 1)
    else 0.5 * (2 - math.exp -LN210 * (t - 1))

math.expo_out_in = (t) ->
  if t < 0.5 then 0.5 * (1 - math.exp -20 * LN2 * t)
  elseif t == 0.5 then 0.5
  else 0.5 * (math.exp(20 * LN2 * (t - 1)) + 1)

-- Circ easing
math.circ_in = (t) ->
  if t < -1 or t > 1 then 0
  else 1 - math.sqrt 1 - t * t

math.circ_out = (t) ->
  if t < 0 or t > 2 then 0
  else math.sqrt t * (2 - t)

math.circ_in_out = (t) ->
  if t < -0.5 or t > 1.5 then 0.5
  else
    t = t * 2
    if t < 1 then -0.5 * (math.sqrt(1 - t * t) - 1)
    else
      t = t - 2
      0.5 * (math.sqrt(1 - t * t) + 1)

math.circ_out_in = (t) ->
  if t < 0 then 0
  elseif t > 1 then 1
  elseif t < 0.5
    t = t * 2 - 1
    0.5 * math.sqrt 1 - t * t
  else
    t = t * 2 - 1
    -0.5 * ((math.sqrt(1 - t * t) - 1) - 1)

-- Bounce easing
math.bounce_in = (t) ->
  t = 1 - t
  if t < 1 / 2.75 then 1 - 7.5625 * t * t
  elseif t < 2 / 2.75
    t = t - 1.5 / 2.75
    1 - (7.5625 * t * t + 0.75)
  elseif t < 2.5 / 2.75
    t = t - 2.25 / 2.75
    1 - (7.5625 * t * t + 0.9375)
  else
    t = t - 2.625 / 2.75
    1 - (7.5625 * t * t + 0.984375)

math.bounce_out = (t) ->
  if t < 1 / 2.75 then 7.5625 * t * t
  elseif t < 2 / 2.75
    t = t - 1.5 / 2.75
    7.5625 * t * t + 0.75
  elseif t < 2.5 / 2.75
    t = t - 2.25 / 2.75
    7.5625 * t * t + 0.9375
  else
    t = t - 2.625 / 2.75
    7.5625 * t * t + 0.984375

math.bounce_in_out = (t) ->
  if t < 0.5
    t = 1 - t * 2
    if t < 1 / 2.75 then (1 - 7.5625 * t * t) * 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      (1 - (7.5625 * t * t + 0.75)) * 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      (1 - (7.5625 * t * t + 0.9375)) * 0.5
    else
      t = t - 2.625 / 2.75
      (1 - (7.5625 * t * t + 0.984375)) * 0.5
  else
    t = t * 2 - 1
    if t < 1 / 2.75 then 7.5625 * t * t * 0.5 + 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      (7.5625 * t * t + 0.75) * 0.5 + 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      (7.5625 * t * t + 0.9375) * 0.5 + 0.5
    else
      t = t - 2.625 / 2.75
      (7.5625 * t * t + 0.984375) * 0.5 + 0.5

math.bounce_out_in = (t) ->
  if t < 0.5
    t = t * 2
    if t < 1 / 2.75 then 7.5625 * t * t * 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      (7.5625 * t * t + 0.75) * 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      (7.5625 * t * t + 0.9375) * 0.5
    else
      t = t - 2.625 / 2.75
      (7.5625 * t * t + 0.984375) * 0.5
  else
    t = 1 - (t * 2 - 1)
    if t < 1 / 2.75 then 0.5 - 7.5625 * t * t * 0.5 + 0.5
    elseif t < 2 / 2.75
      t = t - 1.5 / 2.75
      0.5 - (7.5625 * t * t + 0.75) * 0.5 + 0.5
    elseif t < 2.5 / 2.75
      t = t - 2.25 / 2.75
      0.5 - (7.5625 * t * t + 0.9375) * 0.5 + 0.5
    else
      t = t - 2.625 / 2.75
      0.5 - (7.5625 * t * t + 0.984375) * 0.5 + 0.5

-- Back easing
math.back_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else t * t * ((overshoot + 1) * t - overshoot)

math.back_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t - 1
    t * t * ((overshoot + 1) * t + overshoot) + 1

math.back_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t * 2
    if t < 1 then 0.5 * (t * t * ((overshoot * 1.525 + 1) * t - overshoot * 1.525))
    else
      t = t - 2
      0.5 * (t * t * ((overshoot * 1.525 + 1) * t + overshoot * 1.525) + 2)

math.back_out_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  elseif t < 0.5
    t = t * 2 - 1
    0.5 * (t * t * ((overshoot + 1) * t + overshoot) + 1)
  else
    t = t * 2 - 1
    0.5 * t * t * ((overshoot + 1) * t - overshoot) + 0.5

-- Elastic easing
math.elastic_in = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t - 1
    -(amplitude * math.exp(LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period))

math.elastic_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else math.exp(-LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period) + 1

math.elastic_in_out = (t) ->
  if t == 0 then 0
  elseif t == 1 then 1
  else
    t = t * 2
    if t < 1
      t = t - 1
      -0.5 * (amplitude * math.exp(LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period))
    else
      t = t - 1
      amplitude * math.exp(-LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period) * 0.5 + 1

math.elastic_out_in = (t) ->
  if t < 0.5
    t = t * 2
    if t == 0 then 0
    else (amplitude / 2) * math.exp(-LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period) + 0.5
  else
    if t == 0.5 then 0.5
    elseif t == 1 then 1
    else
      t = t * 2 - 1
      t = t - 1
      -((amplitude / 2) * math.exp(LN210 * t) * math.sin((t * 0.001 - period / 4) * (2 * PI) / period)) + 0.5
