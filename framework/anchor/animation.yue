global *

--[[
  Animation class for sprite sheet animations.

  Animations play through frames of a spritesheet with configurable timing,
  loop modes, and per-frame callbacks.

  Usage:
    -- As object child (recommended)
    @\add animation 'anim', an.spritesheets.hit, 0.03, 'once',
      [3]: => print "frame 3"
      [0]: => @\kill!

    -- Drawing
    layer\animation @anim, x, y, r, sx, sy

  Properties:
    @spritesheet - spritesheet reference
    @frame       - current frame (1-indexed)
    @delay       - frame delay (number or table of per-frame delays)
    @loop_mode   - 'once', 'loop', or 'bounce'
    @actions     - table of callbacks indexed by frame number (0 = completion)
    @playing     - whether animation is playing
    @dead        - true when 'once' animation completes
    @direction   - play direction (1 forward, -1 reverse for bounce)
]]
class animation
  --[[
    Creates a new animation.

    Parameters:
      spritesheet - spritesheet object to animate
      delay       - seconds per frame (number) or per-frame delays (table)
      loop_mode   - 'once' (play once, set dead), 'loop' (repeat), 'bounce' (ping-pong)
      actions     - optional table of callbacks: {[frame]: function, [0]: on_complete}

    Callbacks receive the parent object as self when using fat arrow syntax.
  ]]
  new: (@spritesheet, @delay=0.1, @loop_mode='loop', @actions={}) =>
    @frame = 1
    @timer = 0
    @direction = 1
    @playing = true
    @dead = false
    -- Fire action for frame 1 on creation if it exists
    @\_fire_action 1

  --[[
    Updates animation timing. Called automatically when added to an object.

    Parameters:
      dt - delta time in seconds
  ]]
  update: (dt) =>
    return unless @playing
    return if @dead

    @timer += dt
    current_delay = @\_get_delay @frame

    while @timer >= current_delay and @playing and not @dead
      @timer -= current_delay
      @\_advance_frame!
      current_delay = @\_get_delay @frame

  --[[
    Starts or resumes playback.
  ]]
  play: =>
    @playing = true

  --[[
    Pauses playback without resetting.
  ]]
  stop: =>
    @playing = false

  --[[
    Resets animation to initial state and starts playing.
  ]]
  reset: =>
    @frame = 1
    @timer = 0
    @direction = 1
    @dead = false
    @playing = true
    @\_fire_action 1

  --[[
    Jumps to a specific frame.

    Parameters:
      frame - frame number (1-indexed)
  ]]
  set_frame: (frame) =>
    @frame = math.clamp frame, 1, @spritesheet.frames
    @timer = 0
    @\_fire_action @frame

  -- Internal: get delay for a frame
  _get_delay: (frame) =>
    if type(@delay) == 'table'
      @delay[frame] or @delay[1] or 0.1
    else
      @delay

  -- Internal: fire action callback for a frame
  _fire_action: (frame) =>
    if @actions[frame]
      if @parent
        @actions[frame] @parent
      else
        @actions[frame] @

  -- Internal: advance to next frame based on loop mode
  _advance_frame: =>
    next_frame = @frame + @direction

    if @loop_mode == 'once'
      if next_frame > @spritesheet.frames
        @dead = true
        @playing = false
        @\_fire_action 0
        return
      @frame = next_frame
      @\_fire_action @frame

    elseif @loop_mode == 'loop'
      if next_frame > @spritesheet.frames
        @frame = 1
        @\_fire_action 0
        @\_fire_action @frame
      else
        @frame = next_frame
        @\_fire_action @frame

    elseif @loop_mode == 'bounce'
      if next_frame > @spritesheet.frames
        @direction = -1
        @frame = @spritesheet.frames - 1
        @\_fire_action 0
        @\_fire_action @frame if @frame >= 1
      elseif next_frame < 1
        @direction = 1
        @frame = 2
        @\_fire_action 0
        @\_fire_action @frame if @frame <= @spritesheet.frames
      else
        @frame = next_frame
        @\_fire_action @frame
