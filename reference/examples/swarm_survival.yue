-- =============================================================================
-- SWARM SURVIVAL
-- =============================================================================
-- An example game demonstrating Anchor engine patterns.
-- 
-- Gameplay: You're in the center of an arena. Enemies spawn from the edges
-- and swarm toward you. Your weapons auto-attack. Collect XP orbs to level up.
-- Survive as long as possible.
--
-- Patterns demonstrated:
-- - Object tree with parent/child relationships
-- - Named vs anonymous objects
-- - Operator syntax (^, /, %, //, +, >>)
-- - Single-letter aliases (E, X, A)
-- - Springs for juice/feel
-- - Colliders: sensors (pickups) vs contacts (damage)
-- - Timers: after, every, tween (named and anonymous)
-- - Named actions with X helper
-- - Layers for rendering (game, effects, ui)
-- - Death propagation with kill()
-- - Querying with all()/A()
-- - Tags for categorization
-- - Automatic named linking
-- =============================================================================


--{{{ CONFIGURATION
-- All tunable values in one place for easy adjustment

CONFIG = {
  -- Screen
  width: 480
  height: 270
  
  -- Player
  player_speed: 120
  player_radius: 8
  player_hp: 100
  invincibility_duration: 1.5
  
  -- Enemies
  enemy_base_speed: 40
  enemy_radius: 6
  enemy_damage: 10
  spawn_distance: 180  -- Distance from center where enemies spawn
  
  -- Waves
  initial_spawn_rate: 2.0      -- Seconds between spawns
  min_spawn_rate: 0.3          -- Fastest spawn rate
  spawn_acceleration: 0.95     -- Multiplier per wave
  enemies_per_spawn: 1         -- Starting enemies per spawn
  
  -- XP and Leveling
  xp_per_orb: 10
  xp_per_level: 100
  orb_radius: 4
  orb_attraction_radius: 50
  orb_attraction_speed: 200
  
  -- Weapons
  bullet_speed: 300
  bullet_radius: 3
  bullet_damage: 25
  fire_rate: 0.4  -- Seconds between shots
  
  -- Visual
  colors: {
    player: 0x44AA44FF
    player_hurt: 0xFF4444FF
    enemy: 0xAA4444FF
    bullet: 0xFFFF44FF
    orb: 0x44AAFFFF
    orb_glow: 0x44AAFF44
    ui_text: 0xFFFFFFFF
    ui_bg: 0x00000088
  }
}
--}}}


--{{{ UTILITY FUNCTIONS

-- Distance between two points
dist = (x1, y1, x2, y2) ->
  dx = x2 - x1
  dy = y2 - y1
  math.sqrt(dx * dx + dy * dy)

-- Angle from point 1 to point 2
angle_to = (x1, y1, x2, y2) ->
  math.atan2(y2 - y1, x2 - x1)

-- Normalize a vector, return angle and magnitude
normalize = (x, y) ->
  mag = math.sqrt(x * x + y * y)
  if mag > 0
    x / mag, y / mag, mag
  else
    0, 0, 0

-- Random point on circle edge (for spawning)
random_on_circle = (cx, cy, radius) ->
  angle = an\random_angle!
  cx + math.cos(angle) * radius, cy + math.sin(angle) * radius

--}}}


--{{{ PARTICLE - Anonymous visual effects
-- Demonstrates: Anonymous objects, tweens, self-removal, effects layer

spawn_particle = (x, y, color, args = {}) ->
  -- Anonymous object (no name) - can't be referenced, just visual
  E! ^ {
    x: x
    y: y
    color: color
    radius: args.radius or 4
    vx: args.vx or an\random_float(-50, 50)
    vy: args.vy or an\random_float(-50, 50)
    duration: args.duration or an\random_float(0.3, 0.5)
  }
  ^ =>
    -- Tween radius to 0, then self-destruct
    @\timer!
    @\tween @duration, @, {radius: 0}, math.quad_out, ->
      @\kill!
  / (dt) =>
    @x += @vx * dt
    @y += @vy * dt
    
    -- Draw on effects layer (above game, below UI)
    effects\circle @x, @y, @radius, @color
  >> arena.particles

-- Burst of particles (for death effects, hits, etc.)
spawn_particle_burst = (x, y, color, count = 5) ->
  for i = 1, count
    angle = an\random_angle!
    speed = an\random_float(50, 150)
    spawn_particle x, y, color, {
      vx: math.cos(angle) * speed
      vy: math.sin(angle) * speed
    }

--}}}


--{{{ XP ORB - Collectible pickup
-- Demonstrates: Sensor collider (overlap, no physics), attraction behavior,
--               named timer for delayed attraction, tags

class orb extends object
  new: (x, y) =>
    super nil  -- Anonymous (many orbs, no need to reference individually)
    @x, @y = x, y
    @value = CONFIG.xp_per_orb
    @attracted = false
    @attract_target = nil
    
    @\tag 'orb'
    @\timer!
    
    -- Collider as sensor (no physics response, just overlap detection)
    @ + collider 'orb', 'dynamic', 'circle', CONFIG.orb_radius
    @collider\set_sensor true
    
    -- Spring for "pop in" effect
    @ + spring 'scale', 0, 200, 10
    @scale\pull -1  -- Start at 0, spring to 1
    
    -- Delay before orb can be attracted (prevents instant pickup)
    @\after 0.3, 'attract_delay', ->
      @can_attract = true

  update: (dt) =>
    player = @arena.player
    return unless player and not player.dead
    
    -- Check attraction range
    if @can_attract and not @attracted
      d = dist @x, @y, player.x, player.y
      if d < CONFIG.orb_attraction_radius
        @attracted = true
        @attract_target = player
    
    -- Move toward player if attracted
    if @attracted and @attract_target
      angle = angle_to @x, @y, @attract_target.x, @attract_target.y
      @x += math.cos(angle) * CONFIG.orb_attraction_speed * dt
      @y += math.sin(angle) * CONFIG.orb_attraction_speed * dt
      @collider\set_position @x, @y

  draw: (dt) =>
    s = @scale.x
    -- Glow effect
    effects\circle @x, @y, CONFIG.orb_radius * 2 * s, CONFIG.colors.orb_glow
    -- Core
    game\circle @x, @y, CONFIG.orb_radius * s, CONFIG.colors.orb

  collect: =>
    spawn_particle_burst @x, @y, CONFIG.colors.orb, 3
    @\kill!

--}}}


--{{{ BULLET - Player projectile
-- Demonstrates: Contact collider (physics response), velocity-based movement,
--               collision handling, automatic cleanup on arena exit

class bullet extends object
  new: (x, y, angle) =>
    super nil  -- Anonymous
    @x, @y = x, y
    @angle = angle
    @damage = CONFIG.bullet_damage
    @vx = math.cos(angle) * CONFIG.bullet_speed
    @vy = math.sin(angle) * CONFIG.bullet_speed
    
    @\tag 'bullet'
    
    -- Collider (contact type - will trigger contact events)
    @ + collider 'bullet', 'dynamic', 'circle', CONFIG.bullet_radius
    @collider\set_velocity @vx, @vy
    
    -- Spring for muzzle flash effect
    @ + spring 'flash', 2, 300, 15

  update: (dt) =>
    @x, @y = @collider\get_position!
    
    -- Kill if outside arena bounds
    margin = 20
    if @x < -margin or @x > CONFIG.width + margin or
       @y < -margin or @y > CONFIG.height + margin
      @\kill!

  draw: (dt) =>
    -- Flash effect on spawn
    flash_size = CONFIG.bullet_radius * @flash.x
    effects\circle @x, @y, flash_size, CONFIG.colors.bullet if @flash.x > 1.1
    
    game\circle @x, @y, CONFIG.bullet_radius, CONFIG.colors.bullet

  on_hit: (enemy) =>
    spawn_particle_burst @x, @y, CONFIG.colors.bullet, 2
    @\kill!

--}}}


--{{{ ENEMY - Basic swarming enemy
-- Demonstrates: Seeking behavior, contact damage, death drops, tags,
--               spring for hit feedback

class enemy extends object
  new: (x, y) =>
    super nil  -- Anonymous (many enemies)
    @x, @y = x, y
    @hp = 50
    @speed = CONFIG.enemy_base_speed * an\random_float(0.8, 1.2)
    @damage = CONFIG.enemy_damage
    
    @\tag 'enemy'
    @\timer!
    
    @ + collider 'enemy', 'dynamic', 'circle', CONFIG.enemy_radius
    @collider\set_position x, y
    
    -- Spring for hit flash
    @ + spring 'hit', 1, 300, 10

  update: (dt) =>
    player = @arena.player
    return unless player and not player.dead
    
    -- Move toward player
    angle = angle_to @x, @y, player.x, player.y
    @vx = math.cos(angle) * @speed
    @vy = math.sin(angle) * @speed
    @collider\set_velocity @vx, @vy
    
    @x, @y = @collider\get_position!

  draw: (dt) =>
    -- Flash white when hit (spring > 1)
    color = if @hit.x > 1.1 then 0xFFFFFFFF else CONFIG.colors.enemy
    scale = @hit.x
    
    game\push @x, @y, 0, scale, scale
    game\circle 0, 0, CONFIG.enemy_radius, color
    game\pop!

  take_damage: (amount) =>
    @hp -= amount
    @hit\pull 0.3  -- Trigger hit flash
    
    if @hp <= 0
      @\die!

  die: =>
    -- Spawn XP orb at death location
    orb(@x, @y) >> arena.pickups
    
    -- Death particles
    spawn_particle_burst @x, @y, CONFIG.colors.enemy, 5
    
    @\kill!

--}}}


--{{{ WEAPON - Auto-attacking weapon system
-- Demonstrates: Named actions for weapon behavior, every() timer,
--               querying enemies with A(), targeting logic

class weapon extends object
  new: =>
    super 'weapon'  -- Named (player.weapon)
    @fire_rate = CONFIG.fire_rate
    @can_fire = true
    
    @\timer!
    
    -- Fire rate cooldown using named timer
    @\every @fire_rate, 'fire_cycle', ->
      @can_fire = true

  update: (dt) =>
    return unless @can_fire
    
    -- Find nearest enemy using A() query
    enemies = @arena\A 'enemy'
    return if #enemies == 0
    
    -- Find closest
    closest = nil
    closest_dist = math.huge
    for e in *enemies
      d = dist @parent.x, @parent.y, e.x, e.y
      if d < closest_dist
        closest = e
        closest_dist = d
    
    -- Fire at closest enemy
    if closest
      angle = angle_to @parent.x, @parent.y, closest.x, closest.y
      bullet(@parent.x, @parent.y, angle) >> arena.projectiles
      @can_fire = false
      
      -- Trigger parent's shoot spring for recoil feel
      @parent.shoot\pull 0.2 if @parent.shoot

--}}}


--{{{ PLAYER
-- Demonstrates: Named object, input handling, multiple springs,
--               invincibility frames with named timer, death state

class player extends object
  new: (x, y) =>
    super 'player'  -- Named (arena.player)
    @x, @y = x, y
    @hp = CONFIG.player_hp
    @max_hp = CONFIG.player_hp
    @speed = CONFIG.player_speed
    @invincible = false
    @xp = 0
    @level = 1
    @xp_to_next = CONFIG.xp_per_level
    
    @\tag 'player'
    @\timer!
    
    @ + collider 'player', 'dynamic', 'circle', CONFIG.player_radius
    
    -- Multiple springs for different effects
    @ + spring 'main', 1, 200, 10    -- General scale (hit effect)
    @ + spring 'shoot', 1, 300, 15   -- Recoil on shooting
    
    -- Weapon as child object
    @ + weapon!

  update: (dt) =>
    -- Input handling
    @vx, @vy = 0, 0
    
    @vx -= @speed if an\is_down 'left'
    @vx += @speed if an\is_down 'right'
    @vy -= @speed if an\is_down 'up'
    @vy += @speed if an\is_down 'down'
    
    -- Normalize diagonal movement
    if @vx != 0 and @vy != 0
      @vx *= 0.707
      @vy *= 0.707
    
    @collider\set_velocity @vx, @vy
    
    -- Sync position
    @x, @y = @collider\get_position!
    
    -- Clamp to arena bounds
    @x = math.max(CONFIG.player_radius, math.min(CONFIG.width - CONFIG.player_radius, @x))
    @y = math.max(CONFIG.player_radius, math.min(CONFIG.height - CONFIG.player_radius, @y))
    @collider\set_position @x, @y

  draw: (dt) =>
    -- Combine springs for final scale
    scale = @main.x * @shoot.x
    
    -- Flash when invincible
    color = CONFIG.colors.player
    if @invincible
      -- Blink effect
      color = if math.floor(an.time * 10) % 2 == 0
        CONFIG.colors.player
      else
        CONFIG.colors.player_hurt
    
    game\push @x, @y, 0, scale, scale
    game\circle 0, 0, CONFIG.player_radius, color
    game\pop!

  take_damage: (amount) =>
    return if @invincible
    
    @hp -= amount
    @main\pull 0.5  -- Hit squash
    spawn_particle_burst @x, @y, CONFIG.colors.player_hurt, 3
    
    if @hp <= 0
      @\die!
    else
      -- Invincibility frames
      -- Demonstrates: Named timer that can be replaced
      @invincible = true
      @\after CONFIG.invincibility_duration, 'invincibility', ->
        @invincible = false

  add_xp: (amount) =>
    @xp += amount
    
    -- Level up check
    while @xp >= @xp_to_next
      @xp -= @xp_to_next
      @level += 1
      @xp_to_next = math.floor @xp_to_next * 1.2
      @\on_level_up!

  on_level_up: =>
    -- Visual feedback
    @main\pull -0.3  -- Pop larger
    spawn_particle_burst @x, @y, 0xFFFFFFFF, 8
    
    -- Could add upgrade choices here
    -- For now, just heal a bit
    @hp = math.min(@hp + 20, @max_hp)

  die: =>
    spawn_particle_burst @x, @y, CONFIG.colors.player, 10
    @arena\game_over!
    @\kill!

--}}}


--{{{ ARENA - Main game container
-- Demonstrates: Root object, containers for organization, collision handling,
--               wave spawning system, early/late actions, game state

class arena extends object
  new: =>
    super 'arena'  -- Named (root of game tree)
    @game_active = true
    @wave = 0
    @spawn_rate = CONFIG.initial_spawn_rate
    @enemies_per_spawn = CONFIG.enemies_per_spawn
    @score = 0
    
    @\timer!
    
    --{{{ Input bindings
    an\input_bind 'left', {'key:a', 'key:left', 'gamepad:leftx-'}
    an\input_bind 'right', {'key:d', 'key:right', 'gamepad:leftx+'}
    an\input_bind 'up', {'key:w', 'key:up', 'gamepad:lefty-'}
    an\input_bind 'down', {'key:s', 'key:down', 'gamepad:lefty+'}
    --}}}
    
    --{{{ Physics setup
    an\physics_set_gravity 0, 0  -- Top-down, no gravity
    
    -- Configure what collides with what
    -- Contacts: physical collision with response
    an\physics_enable_contact_between 'bullet', {'enemy'}
    an\physics_enable_contact_between 'player', {'enemy'}
    
    -- Sensors: overlap detection, no physics response
    an\physics_enable_sensor_between 'player', {'orb'}
    --}}}
    
    --{{{ Container objects for organization
    -- These are named so we can reference them: arena.enemies, arena.pickups, etc.
    -- Demonstrates: Named containers, tree structure
    
    @ + E 'enemies'     -- Container for all enemies
    @ + E 'projectiles' -- Container for bullets
    @ + E 'pickups'     -- Container for XP orbs
    @ + E 'particles'   -- Container for visual effects
    --}}}
    
    --{{{ Create player
    -- Player is added directly to arena, not a container
    @ + player CONFIG.width / 2, CONFIG.height / 2
    --}}}
    
    --{{{ Wave spawning system
    @\start_spawning!
    --}}}

  early_update: (dt) =>
    return unless @game_active
    
    -- Bullet vs Enemy (contact - they bounce)
    for c in *an\physics_get_contact_enter 'bullet', 'enemy'
      b, e = c.a, c.b
      e\take_damage b.damage
      b\on_hit e
    
    -- Player vs Enemy (contact - they bounce)
    for c in *an\physics_get_contact_enter 'player', 'enemy'
      p, e = c.a, c.b
      p\take_damage e.damage unless p.invincible
    
    -- Player vs Orb (sensor - player passes through)
    for c in *an\physics_get_sensor_enter 'player', 'orb'
      p, o = c.a, c.b
      p\add_xp o.value
      o\collect!
      @score += o.value

  draw: (dt) =>
    return unless @player and not @player.dead
    
    -- HP bar
    bar_width = 60
    bar_height = 6
    bar_x = 10
    bar_y = 10
    hp_ratio = @player.hp / @player.max_hp
    
    ui\rectangle bar_x, bar_y, bar_width, bar_height, 0, 0, 0x333333FF
    ui\rectangle bar_x, bar_y, bar_width * hp_ratio, bar_height, 0, 0, CONFIG.colors.player
    
    -- XP bar
    xp_y = bar_y + bar_height + 4
    xp_ratio = @player.xp / @player.xp_to_next
    ui\rectangle bar_x, xp_y, bar_width, bar_height, 0, 0, 0x333333FF
    ui\rectangle bar_x, xp_y, bar_width * xp_ratio, bar_height, 0, 0, CONFIG.colors.orb
    
    -- Level and score
    ui\draw_text "Lv.#{@player.level}", 'default', bar_x + bar_width + 8, bar_y + 2, CONFIG.colors.ui_text
    ui\draw_text "Score: #{@score}", 'default', CONFIG.width - 80, bar_y + 2, CONFIG.colors.ui_text
    ui\draw_text "Wave #{@wave}", 'default', CONFIG.width / 2 - 20, bar_y + 2, CONFIG.colors.ui_text

  start_spawning: =>
    @wave += 1
    
    -- Spawn enemies at current rate
    -- Demonstrates: Named every() timer that gets replaced each wave
    @\every @spawn_rate, 'spawner', ->
      @\spawn_enemies!
    
    -- Increase difficulty for next wave
    @\after 10, 'wave_timer', ->
      @spawn_rate = math.max CONFIG.min_spawn_rate, @spawn_rate * CONFIG.spawn_acceleration
      @enemies_per_spawn += 1 if @wave % 3 == 0
      @\start_spawning!  -- Restart with new rate

  spawn_enemies: =>
    return unless @game_active
    
    cx, cy = CONFIG.width / 2, CONFIG.height / 2
    
    for i = 1, @enemies_per_spawn
      x, y = random_on_circle cx, cy, CONFIG.spawn_distance
      enemy(x, y) >> @enemies

  game_over: =>
    @game_active = false
    
    -- Kill spawner
    @spawner\kill! if @spawner
    @wave_timer\kill! if @wave_timer
    
    -- Could show game over UI here
    -- For now, just stop the game

--}}}


--{{{ MAIN - Entry point
-- Demonstrates: Layer creation, game initialization

init = ->
  -- Create rendering layers (engine infrastructure, not tree objects)
  -- Order matters: game draws first, effects on top, UI on top of that
  export game = an\layer 'game'
  export effects = an\layer 'effects'
  export ui = an\layer 'ui'
  
  -- Load font for UI
  an\font_load 'default', 'assets/fonts/default.ttf', 12
  
  -- Seed RNG for determinism (optional)
  an\random_seed os.time!
  
  -- Create the arena (root of game tree)
  export arena = arena!

-- Engine calls this once at startup
an.init = init

--}}}


-- =============================================================================
-- TREE STRUCTURE AT RUNTIME
-- =============================================================================
-- 
-- arena (named 'arena')
-- ├── player (named 'player')
-- │   ├── collider
-- │   ├── main_spring
-- │   ├── shoot_spring
-- │   └── weapon (named 'weapon')
-- ├── enemies (named 'enemies')
-- │   ├── enemy (anonymous)
-- │   │   ├── collider
-- │   │   └── hit_spring
-- │   ├── enemy (anonymous)
-- │   └── ...
-- ├── projectiles (named 'projectiles')
-- │   ├── bullet (anonymous)
-- │   │   ├── collider
-- │   │   └── flash_spring
-- │   └── ...
-- ├── pickups (named 'pickups')
-- │   ├── orb (anonymous)
-- │   │   ├── collider
-- │   │   └── scale_spring
-- │   └── ...
-- └── particles (named 'particles')
--     ├── particle (anonymous)
--     └── ...
-- 
-- =============================================================================


-- =============================================================================
-- PATTERNS DEMONSTRATED
-- =============================================================================
--
-- 1. NAMED VS ANONYMOUS OBJECTS
--    - arena, player, weapon: Named (can be referenced: arena.player)
--    - enemies, bullets, particles: Anonymous (many instances, no need to reference)
--
-- 2. OPERATOR SYNTAX
--    - ^ for initialization: E! ^ {x: 100, y: 200}
--    - / for inline actions: (used in spawn_particle for anonymous objects)
--    - + for adding children: @ + spring 'main', 1, 200, 10
--    - >> for flowing to parent: enemy(x, y) >> @enemies
--
-- 3. SINGLE-LETTER ALIASES
--    - E for object: E 'name' or E! for anonymous
--    - X for named actions: X 'name', fn (inline objects only)
--    - A for querying: @\A 'enemy' returns all tagged 'enemy'
--
-- 4. SPRINGS FOR JUICE
--    - Hit flash: @hit\pull 0.3 then check @hit.x > 1
--    - Scale pop: Start spring at 0, pull to animate in
--    - Recoil: @shoot\pull 0.2 on firing
--
-- 5. SENSORS VS CONTACTS
--    - Sensors: Orb pickup (player passes through, triggers event)
--    - Contacts: Bullet-enemy collision (physics response + event)
--
-- 6. TIMERS
--    - Anonymous: @\after 0.3, -> @can_attract = true
--    - Named (replaceable): @\after 1.5, 'invincibility', -> @invincible = false
--    - Repeating: @\every @fire_rate, 'fire_cycle', -> @can_fire = true
--    - Tween: @\tween 0.5, @, {radius: 0}, math.quad_out, -> @\kill!
--
-- 7. CLASS METHODS VS NAMED ACTIONS
--    - Class-based objects use methods: update:, draw:, early_update:
--    - Engine calls these automatically
--    - Named actions with X only for inline objects or dynamic behavior
--
-- 8. CONTAINERS FOR ORGANIZATION
--    - Named empty objects as containers: @ + E 'enemies'
--    - Add children to containers: enemy(x, y) >> @enemies
--    - Query across containers: @\A 'enemy' searches all descendants
--
-- 9. COLLISION HANDLING
--    - Configured at startup: an\physics_enable_contact_between 'a', {'b', 'c'}
--    - Queried each frame: for c in *an\physics_get_contact_enter 'a', 'b'
--    - Sensor events for triggers: an\physics_get_sensor_enter 'player', 'orb'
--
-- 10. DEATH PROPAGATION
--     - @\kill! immediately sets .dead = true on self and all descendants
--     - Actual removal at end of frame
--     - Children never outlive parents
--
-- =============================================================================
